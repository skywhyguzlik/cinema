<Window x:Class="cinema.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Кинотеатр" Height="700" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#5b386e" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <TextBlock Text="КИНОТЕАТР" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="LoginButton" Content="Вход" Click="LoginButton_Click" Width="70" Height="30" Margin="5,0" Background="White"/>
                    <Button x:Name="RegisterButton" Content="Регистрация" Click="RegisterButton_Click" Width="90" Height="30" Margin="5,0" Background="White"/>
                    <Button x:Name="ProfileButton" Content="Личный кабинет" Click="ProfileButton_Click" Width="120" Height="30" Margin="5,0" Background="LightGreen" Visibility="Collapsed"/>
                    <Button x:Name="LogoutButton" Content="Выход" Click="LogoutButton_Click" Width="60" Height="30" Margin="5,0" Background="LightCoral" Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>