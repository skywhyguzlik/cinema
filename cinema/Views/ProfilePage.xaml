<Page x:Class="cinema.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:cinema.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
       Title="Личный кабинет">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="← Назад" Width="80" Height="30" HorizontalAlignment="Left" Click="BackButton_Click"/>

        <StackPanel Grid.Row="1" Margin="0,10,0,20">
            <TextBlock x:Name="UserNameText" FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Name="UserEmailText" Margin="0,5,0,0"/>
            <TextBlock x:Name="UserBirthText" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Мои билеты" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListView x:Name="TicketsListView" Grid.Row="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Фильм" DisplayMemberBinding="{Binding MovieTitle}" Width="200"/>
                        <GridViewColumn Header="Зал" DisplayMemberBinding="{Binding HallName}" Width="100"/>
                        <GridViewColumn Header="Дата и время" DisplayMemberBinding="{Binding DateTime}" Width="150"/>
                        <GridViewColumn Header="Место" DisplayMemberBinding="{Binding SeatDisplay}" Width="100"/>
                        <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding PricePaid}" Width="80"/>
                        <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="80"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Page>
