<Page x:Class="cinema.Views.MoviePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:cinema.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Информация о фильме">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <Button Content="← Назад" Width="80" Height="30" HorizontalAlignment="Left" Margin="0,0,0,10" Click="BackButton_Click"/>

            <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="200" Height="300" Background="LightGray" CornerRadius="8">
                    <Image x:Name="PosterImage" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock x:Name="RatingText" FontSize="16" Margin="0,0,0,5"/>
                    <TextBlock x:Name="GenreText" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <TextBlock x:Name="AgeRatingText" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DurationText" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ReleaseDateText" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="Сеансы" FontSize="18" FontWeight="Bold" Margin="0,20,0,10"/>
            <ListBox x:Name="SessionsListBox" Height="200" DisplayMemberPath="DisplayText" SelectionChanged="SessionsListBox_SelectionChanged"/>
            <Button x:Name="SelectSessionButton" Content="Выбрать сеанс" Width="150" Height="30" Margin="0,10,0,0" Click="SelectSessionButton_Click" IsEnabled="False"/>
        </StackPanel>
    </ScrollViewer>
</Page>
